# Strele2 arhiv — kopiraj v .env in prilagodi vrednosti.

# Lokalna PostgreSQL (docker compose service db, port 5433 na hostu)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/strele_archive

# StormAPI (strele ingest + widget podatki)
API_BASE_URL=http://127.0.0.1:3000
STRELKO_API_URL=http://127.0.0.1:3000
STORM_API_BASE_URL=http://127.0.0.1:3000/api/v1

# Strele2 HTTP storitve
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
OBCINE_PUBLIC_PORT=8083
POLL_INTERVAL_SEC=300

# Javni dostop do arhiva / widget API
ARHIV_OPEN_ACCESS=1
ARHIV_REQUIRE_STRELKO_LOGIN=1

# Widget: natančen čas zadnje strele (minute) iz strele.udari v StormAPI bazi.
# Na hostu: zamenjaj db:5432 z 127.0.0.1:5432 glede na StormAPI docker-compose.
UDARI_DATABASE_URL=postgresql://app:REPLACE_ME@127.0.0.1:5432/app

# Opcijsko: koliko dni nazaj iskati zadnjo strelo (privzeto 365)
# WIDGET_LAST_STRIKE_DAYS=365
